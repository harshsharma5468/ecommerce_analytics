# ──────────────────────────────────────────────────────────────────────────────
# NexaCommerce Analytics Configuration
# ──────────────────────────────────────────────────────────────────────────────

# ──────────────────────────────────────────────────────────────────────────────
# PostgreSQL Database
# ──────────────────────────────────────────────────────────────────────────────
DB_HOST=postgres
DB_PORT=5432
DB_NAME=ecommerce_analytics
DB_USER=analytics_user
DB_PASSWORD=analytics_pass

# ──────────────────────────────────────────────────────────────────────────────
# Redis Cache
# ──────────────────────────────────────────────────────────────────────────────
REDIS_HOST=redis
REDIS_PORT=6379

# ──────────────────────────────────────────────────────────────────────────────
# Streamlit Dashboard
# ──────────────────────────────────────────────────────────────────────────────
STREAMLIT_SERVER_PORT=8501
STREAMLIT_SERVER_ADDRESS=0.0.0.0

# ──────────────────────────────────────────────────────────────────────────────
# Logging
# ──────────────────────────────────────────────────────────────────────────────
LOG_LEVEL=INFO

# ──────────────────────────────────────────────────────────────────────────────
# Data Generation Parameters
# ──────────────────────────────────────────────────────────────────────────────
N_CUSTOMERS=15000
N_PRODUCTS=500
N_TRANSACTIONS=180000
N_SESSIONS=208000

# ──────────────────────────────────────────────────────────────────────────────
# A/B Testing Parameters
# ──────────────────────────────────────────────────────────────────────────────
AB_ALPHA=0.05
AB_BETA=0.20
AB_MDE=0.05
AB_POWER=0.80

# ──────────────────────────────────────────────────────────────────────────────
# Feature Store
# ──────────────────────────────────────────────────────────────────────────────
FEATURE_STORE_PATH=./feature_store

# ──────────────────────────────────────────────────────────────────────────────
# Streaming Configuration
# ──────────────────────────────────────────────────────────────────────────────
STREAMING_ENABLED=false
STREAMING_RATE=10.0

# ──────────────────────────────────────────────────────────────────────────────
# dbt Configuration
# ──────────────────────────────────────────────────────────────────────────────
DBT_PROFILES_DIR=.
DBT_TARGET=dev

# ──────────────────────────────────────────────────────────────────────────────
# Optional: Third-party Integrations
# ──────────────────────────────────────────────────────────────────────────────
# SLACK_WEBHOOK_URL=
# SENTRY_DSN=
# DATADOG_API_KEY=
