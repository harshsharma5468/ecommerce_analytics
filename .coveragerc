[run]
source = src
branch = True
omit = 
    */__init__.py
    */tests/*
    */test_*
    */venv/*
    */.venv/*

[report]
exclude_lines =
    pragma: no cover
    def __repr__
    raise AssertionError
    raise NotImplementedError
    if __name__ == .__main__.:
    if TYPE_CHECKING:

show_missing = True
precision = 2

[html]
directory = htmlcov
